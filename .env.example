# Server
PORT=3000

# PostgreSQL — Railway connection string
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Redis — BullMQ queue para pipeline de IA (Spec B)
# Upstash: https://console.upstash.com | Railway Redis plugin: redis://default:<pwd>@<host>:<port>
REDIS_URL=redis://localhost:6379

# Tempo máx. (ms) que POST /entries/photo aguarda a análise da IA terminar antes de
# responder com analysis_status:'pending'. A captura nunca falha por timeout.
ANALYSIS_WAIT_TIMEOUT_MS=50000

# Anthropic — Claude vision para análise de fotos (Spec B)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Z-API — WhatsApp integration
# Encontre no painel Z-API em: https://app.z-api.io
ZAPI_INSTANCE=your-instance-id
ZAPI_TOKEN=your-api-token
# Opcional: token de segurança do webhook (configure no painel Z-API como "Client-Token")
# ZAPI_WEBHOOK_SECRET=your-webhook-secret

# Cloudflare R2 — Object storage para fotos
# Encontre em: Cloudflare Dashboard > R2 > Manage R2 API Tokens
R2_BUCKET=your-bucket-name
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY=your-access-key-id
R2_SECRET_KEY=your-secret-access-key
# URL pública do bucket R2 — configure uma das opções abaixo:
# Opção 1 (R2.dev): ative em Cloudflare Dashboard > R2 > seu bucket > Public Access
#   R2_PUBLIC_URL=https://pub-XXXXXXXXXXXX.r2.dev
# Opção 2 (domínio próprio): configure Custom Domain no mesmo painel
#   R2_PUBLIC_URL=https://media.seudominio.com
R2_PUBLIC_URL=https://pub-XXXXXXXXXXXX.r2.dev

# Web app de revisão diária (CAP-3) — origem permitida no CORS.
# Opcional: se omitido, o CORS reflete qualquer origem (ok para uso pessoal, auth é Bearer).
# Em produção, fixe a origem do web app (ex.: https://foodlog.seudominio.com).
# WEB_APP_ORIGIN=http://localhost:5173

# Auditabilidade — quando 'true' (padrão), toda requisição recebida é gravada em
# request_logs e fica visível na aba "Auditoria" do web app. Defina 'false' para desligar.
AUDIT_ENABLED=true
